    { "name": "opening", "kwargs": { "radius": 5 }, "renders_image": true },
    { "name": "threshold", "kwargs": { "method": "otsu" }, "renders_image": true },
    { "name": "blob_log", "kwargs": { "min_sigma": 10.0, "max_sigma": 15.0, "threshold_rel": 0.5 }, "renders_image": false }
  ]
