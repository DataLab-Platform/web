# Build / dependencies
node_modules/
**/node_modules/
dist/
**/dist/
build/
release/
*.tsbuildinfo

# Compiled Vite config (source of truth is vite.config.ts; the .js/.d.ts
# files are generated and tracked only for editor convenience)
vite.config.js
vite.config.d.ts

# Locally-compiled Vite plugins (the .ts source is authoritative; the
# .js sibling is a build artefact, regenerated by the dev server)
build-plugins/*.js

