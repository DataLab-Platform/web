coverage-python.xml
htmlcov-python/
playwright-report/
test-results/
.playwright/
tests/benchmark/results/
tests/benchmark/.cache/

# Python
__pycache__/
**/__pycache__/
.pytest_cache/
.ruff_cache/
.venv/

# npm lockfile (managed by npm — Prettier would only churn it)
package-lock.json

