{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🧽 Ruff Formatter",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "scripts/run_with_env.py",
        "${command:python.interpreterPath}",
        "-m",
        "ruff",
        "format",
        "src/runtime",
        "tests/python",
        "scripts"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "statusbar": {
          "hide": true
        }
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "🔦 Ruff Linter",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "scripts/run_with_env.py",
        "${command:python.interpreterPath}",
        "-m",
        "ruff",
        "check",
        "--fix",
        "src/runtime",
        "tests/python",
        "scripts"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "statusbar": {
          "hide": true
        }
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "🧽🔦 Ruff",
      "dependsOrder": "sequence",
      "dependsOn": ["🧽 Ruff Formatter", "🔦 Ruff Linter"],
      "group": "build",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "🔦 Pylint",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "scripts/run_with_env.py",
        "${command:python.interpreterPath}",
        "-m",
        "pylint",
        "src/runtime"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "🟦 ESLint (TS)",
      "type": "shell",
      "command": "npm",
      "args": ["run", "lint"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "🧽 Prettier (TS)",
      "type": "shell",
      "command": "npm",
      "args": ["run", "format"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "🔍 Prettier check (TS)",
      "detail": "Read-only Prettier formatting check (same as CI's 'Prettier check' step).",
      "type": "shell",
      "command": "npm",
      "args": ["run", "format:check"],
      "options": {
        "cwd": "${workspaceFolder}",
        "statusbar": {
          "hide": true
        }
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "🌍 i18n: Extract keys (step 1/2)",
      "detail": "Step 1/2 — scan src/ for t(\"…\") calls and merge new keys into src/locales/fr.json (empty placeholders). Then fill the new French values by hand, and run step 2/2 to verify.",
      "type": "shell",
      "command": "npm",
      "args": ["run", "i18n:extract"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "🌍 i18n: Check catalog (step 2/2)",
      "detail": "Step 2/2 — verify every referenced key is present and non-empty in src/locales/fr.json (read-only; same check as CI). Run after filling in the French translations.",
      "type": "shell",
      "command": "npm",
      "args": ["run", "i18n:check"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "🚀 Pytest (Python)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "scripts/run_with_env.py",
        "${command:python.interpreterPath}",
        "-m",
        "pytest",
        "tests/python",
        "--ff"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "🧪 Coverage tests (Python)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "scripts/run_with_env.py",
        "${command:python.interpreterPath}",
        "-m",
        "coverage",
        "run",
        "-m",
        "pytest",
        "tests/python"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "statusbar": {
          "hide": true
        }
      },
      "group": "test",
      "presentation": {
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "📊 Generate Coverage HTML (Python)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "scripts/run_with_env.py",
        "${command:python.interpreterPath}",
        "-m",
        "coverage",
        "html"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "statusbar": {
          "hide": true
        }
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "silent"
      },
      "problemMatcher": []
    },
    {
      "label": "📊 Serve Coverage HTML (Python)",
      "detail": "Background HTTP server on http://127.0.0.1:8765/ for the coverage report. Idempotent: silently exits if the port is already taken.",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["scripts/serve_coverage.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "statusbar": {
          "hide": true
        }
      },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "reveal": "silent"
      },
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "READY",
            "endsPattern": "READY"
          }
        }
      ]
    },
    {
      "label": "📊 Coverage full (Python)",
      "type": "shell",
      "command": "echo",
      "args": [
        "Coverage report served at http://127.0.0.1:8765/ — opening in Simple Browser…",
        "${input:openCoverageInSimpleBrowser}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "silent"
      },
      "problemMatcher": [],
      "dependsOrder": "sequence",
      "dependsOn": [
        "🧪 Coverage tests (Python)",
        "📊 Generate Coverage HTML (Python)",
        "📊 Serve Coverage HTML (Python)"
      ]
    },
    {
      "label": "🟢 Vitest (TS)",
      "detail": "Mirrors CI's TypeScript job: Prettier check + ESLint + Vitest.",
      "dependsOrder": "sequence",
      "dependsOn": [
        "🔍 Prettier check (TS)",
        "🟦 ESLint (TS)",
        "🟢 Vitest run (TS)"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "🟢 Vitest run (TS)",
      "detail": "Run Vitest only (no Prettier/ESLint). Use '🟢 Vitest (TS)' for the full CI-equivalent check.",
      "type": "shell",
      "command": "npm",
      "args": ["test"],
      "options": {
        "cwd": "${workspaceFolder}",
        "statusbar": {
          "hide": true
        }
      },
      "problemMatcher": []
    },
    {
      "label": "🔍 Audit shims (versions)",
      "detail": "Report which temporary backport shims are now removable by comparing each shim's removableFrom with the version resolved at runtime (PyPI / pyodide-lock). Report-only; needs network.",
      "type": "shell",
      "command": "npm",
      "args": ["run", "audit:shims"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "🟢 Vitest watch",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test:watch"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "🟢 Vitest with coverage",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test:cov"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "🎭 Playwright (E2E)",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test:e2e"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "🎭 Playwright UI",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test:e2e:ui"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "🎬 Update demo GIF",
      "detail": "Record the scripted Playwright demo and encode doc/images/datalab-web-demo.gif.",
      "type": "shell",
      "command": "npm",
      "args": ["run", "demo:gif"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "🚀 Dev Server",
      "detail": "Background Vite dev server on http://localhost:5173/.",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}",
        "statusbar": {
          "hide": true
        }
      },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "reveal": "silent"
      },
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "VITE v",
            "endsPattern": "ready in"
          }
        }
      ]
    },
    {
      "label": "🌐 Run DataLab-Web in VS Code",
      "detail": "Start the Vite dev server (if not running) and open the app in VS Code's Simple Browser.",
      "type": "shell",
      "command": "echo",
      "args": [
        "DataLab-Web running on http://localhost:5173/ — opening in Simple Browser…",
        "${input:openAppInSimpleBrowser}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "silent"
      },
      "problemMatcher": [],
      "dependsOrder": "sequence",
      "dependsOn": ["🚀 Dev Server"]
    },
    {
      "label": "📦 Release Package (app + SDK)",
      "detail": "Lint + Vitest + build, then produce datalab-web-<v>.tgz and datalab-platform-web-sdk-<v>.tgz under release/.",
      "type": "shell",
      "command": "npm",
      "args": ["run", "release:pack"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "focus": true,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "🚀 Release (bump + commit + tag)",
      "detail": "Atomically bump app + SDK versions, create the release commit and the vX.Y.Z tag. Push remains manual.",
      "type": "shell",
      "command": "node",
      "args": ["scripts/release.mjs", "${input:newVersion}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "focus": true,
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "openCoverageInSimpleBrowser",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": "http://127.0.0.1:8765/"
    },
    {
      "id": "openAppInSimpleBrowser",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": "http://localhost:5173/"
    },
    {
      "id": "newVersion",
      "type": "promptString",
      "description": "New version (SemVer like 0.2.0, or keyword: patch | minor | major | prerelease)",
      "default": "minor"
    }
  ]
}
